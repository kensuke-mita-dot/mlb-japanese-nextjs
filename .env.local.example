# =====================================================
# MLB 日本人選手ウィジェット — 環境変数サンプル
# .env.local にコピーして値を設定してください
# =====================================================

# ---- Upstash Redis (本番: Vercel Marketplace から追加すると自動設定される) ----
# ローカル開発では省略可能（メモリキャッシュで代替）
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxx

# ---- Anthropic API (任意: 通算成績に日本語コメントを付与する場合) ----
# 未設定でも動作します（コメントなしで MLB Stats API の数値データを表示）
# ANTHROPIC_API_KEY=sk-ant-xxxxxx

# ---- Cron Job セキュリティ ----
# Vercel Cron から /api/cron を呼ぶ際の認証トークン
# Vercel 環境変数に CRON_SECRET として登録してください
# CRON_SECRET=your-random-secret-here
